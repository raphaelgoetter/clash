{
  "name": "trustroyale",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "lsof -ti:3000 | xargs kill -9 2>/dev/null; true",
    "dev": "concurrently --names \"backend,frontend\" --prefix-colors \"cyan,magenta\" \"cd backend && npx nodemon server.js\" \"cd frontend && npx vite\"",
    "snapshot": "node scripts/collectSnapshots.js",
    "pre-reset-snapshot": "node scripts/preResetSnapshot.js",
    "notify-members": "node scripts/notifyMemberChanges.js",
    "notify-members:dry": "node scripts/notifyMemberChanges.js --dry-run",
    "notify-members:sim": "node scripts/notifyMemberChanges.js --dry-run --simulate",
    "last-seen": "node scripts/notifyLastSeen.js",
    "last-seen:dry": "node scripts/notifyLastSeen.js --dry-run",
    "clan-status": "node scripts/notifyClanStatus.js",
    "clan-status:dry": "node scripts/notifyClanStatus.js --dry-run",
    "ping-test": "node scripts/ping-test.js",
    "war-summary": "node scripts/notifyWarSummary.js",
    "war-summary:dry": "node scripts/notifyWarSummary.js --dry-run",
    "pre-war-summary": "node scripts/notifyPreWarSummary.js",
    "pre-war-summary:dry": "node scripts/notifyPreWarSummary.js --dry-run",
    "gdc-launch": "node scripts/notifyGdcLaunch.js",
    "gdc-launch:dry": "node scripts/notifyGdcLaunch.js --dry-run",
    "predictions:start": "node scripts/autoStartPredictions.js",
    "predictions:start:dry": "node scripts/autoStartPredictions.js --dry-run",
    "predictions:end": "node scripts/autoEndPredictions.js",
    "predictions:end:dry": "node scripts/autoEndPredictions.js --dry-run",
    "frame:test": "node scripts/postFrame.js",
    "frame:test:dry": "node scripts/postFrame.js --dry-run",
    "frame:public": "node scripts/postFrame.js --public",
    "frame:public:dry": "node scripts/postFrame.js --public --dry-run",
    "frame:reset": "node scripts/resetFrame.js",
    "frame:scores": "node scripts/frameScores.js",
    "rules": "node scripts/notifyRules.js",
    "rules:dry": "node scripts/notifyRules.js --dry-run",
    "rules:dry:noping": "node scripts/notifyRules.js --dry-run --no-ping",
    "cache": "node scripts/refreshClanCache.js",
    "prebuild": "npm run cache",
    "cache:clear": "rm -f frontend/public/clan-cache/*.json",
    "deploy": "npm run cache:clear && npm run build && vercel --prod --confirm --force",
    "build": "cd frontend && npm run build && cd .. && vercel --prod",
    "test": "node backend/services/analysisService.test.js && node backend/services/snapshot.test.js && node backend/services/notifyWarSummary.test.js && node backend/services/notifyLastSeen.test.js && node backend/services/notifyClanStatus.test.js"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.3.0",
    "@upstash/redis": "^1.38.0",
    "@vercel/blob": "^2.5.0",
    "@vercel/functions": "^3.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "discord-interactions": "^1.5.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
