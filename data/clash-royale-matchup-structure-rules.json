  "_crossRulesHelp": "Chaque règle se déclenche si `trigger` matche le deck évalué (self), puis compte les cartes du deck adverse (opponent) présentes dans `watch.cardSets`. Le premier `thresholds[]` dont la condition (op/value sur ce compte) est vraie s'applique. `{self}`/`{opponent}` = 'toi'/'lui' (ou l'inverse selon le camp évalué), `{count}` = nombre trouvé, `{triggerCard}` = nom de la carte qui a déclenché un trigger de type cardSet.",
  "crossRules": [
    {
      "id": "bait",
      "description": "toi: Bait / lui: 0 petit sort -> +6% pour toi. toi: Bait / lui: 2+ petits sorts -> -6% pour toi.",
      "trigger": { "type": "archetype", "value": "Bait" },
      "watch": { "cardSets": ["smallSpells"] },
      "thresholds": [
        {
          "op": "lt",
          "value": 1,
          "shift": 6,
          "label": "{opponent} 0 petit sort\n- {self} Bait"
        },
        {
          "op": "gte",
          "value": 2,
          "shift": -6,
          "label": "{opponent} {count} petits sorts\n- {self} Bait"
        }
      ]
    },
    {
      "id": "splitPush",
      "description": "toi: carte de push agressif (Three Musketeers, Royal Hogs) / lui: 0 gros sort -> +6% pour toi.",
      "trigger": { "type": "cardSet", "value": "splitPushTriggerCards" },
      "watch": { "cardSets": ["bigSpells"] },
      "thresholds": [
        {
          "op": "eq",
          "value": 0,
          "shift": 6,
          "label": "{opponent} 0 gros sort\n- {self} {triggerCard} (push)"
        }
      ]
    },
    {
      "id": "heavyBeatdown",
      "description": "toi: win condition Heavy Beatdown (Golem, Giant, Electro Giant, Lava Hound) / lui: 0 tank killer et 0 bâtiment défensif -> +10% pour toi.",
      "trigger": { "type": "cardSet", "value": "heavyBeatdownWinConditions" },
      "watch": { "cardSets": ["tankKillers", "defensiveBuildings"] },
      "thresholds": [
        {
          "op": "eq",
          "value": 0,
          "shift": 10,
          "label": "{opponent} aucun tank killer/bâtiment\n- {self} Gros tank"
        }
      ]
    },
    {
      "id": "heavyDpsHardCounter",
      "description": "toi: Ronin/P.E.K.K.A/Mini P.E.K.K.A dans le deck / lui: au moins 1 carte à gros DPS (P.E.K.K.A, Mini P.E.K.K.A, Prince, Mega Knight, Boss Bandit, Bandit, Golden Knight) -> +6% pour toi (hard-counter).",
      "trigger": { "type": "cardSet", "value": "heavyDpsHardCounters" },
      "watch": { "cardSets": ["heavyDpsThreats"] },
      "thresholds": [
        {
          "op": "gte",
          "value": 1,
          "shift": 6,
          "label": "{opponent} {count} gros DPS\n- {self} {triggerCard} (hard-counter)"
        }
      ]
    },
    {
      "id": "heavyDpsSoftCounter",
      "description": "toi: Prince/Mega Knight/Boss Bandit/Bandit/Golden Knight/Knight/Valkyrie/Skeleton Army/Goblin Gang dans le deck / lui: au moins 1 carte à gros DPS -> +3% pour toi (soft-counter).",
      "trigger": { "type": "cardSet", "value": "heavyDpsSoftCounters" },
      "watch": { "cardSets": ["heavyDpsThreats"] },
      "thresholds": [
        {
          "op": "gte",
          "value": 1,
          "shift": 3,
          "label": "{opponent} {count} gros DPS\n- {self} {triggerCard} (soft-counter)"
        }
      ]
    }
  ],

  "_dispersionRulesHelp": "Auto-pénalité en échelle triangulaire (indépendante du deck adverse) : au-delà de `baseline` occurrences, chaque unité supplémentaire coûte `unitPoints` de plus que la précédente (1, 2, 3, 4... points cumulés). `metric` = 'winConditionCount' (nombre de win conditions reconnues), ou `cardSets` = somme des cartes du deck dans ces catégories.",
  "dispersionRules": [
    {
      "id": "winConditions",
      "description": "Plus de 2 win conditions reconnues dans le deck.",
      "metric": "winConditionCount",
      "baseline": 2,
      "unitPoints": 4,
      "label": "{self} {count} WC (dispersion)"
    },
    {
      "id": "spells",
      "description": "Plus de 3 sorts (petits + gros) dans le deck.",
      "cardSets": ["smallSpells", "bigSpells"],
      "baseline": 3,
      "unitPoints": 4,
      "label": "{self} {count} sorts (dispersion)"
    },
    {
      "id": "buildings",
      "description": "Plus de 2 bâtiments défensifs dans le deck.",
      "cardSets": ["defensiveBuildings"],
      "baseline": 2,
      "unitPoints": 4,
      "label": "{self} {count} bâtiments (dispersion)"
    }
  ],

  "_selfRulesHelp": "Carences du deck évalué lui-même (indépendant de l'adversaire) : compte les cartes de `watch.cardSets` dans le deck, applique le premier `thresholds[]` dont la condition est vraie. Toujours des pénalités (shift négatif).",
  "selfRules": [
    {
      "id": "antiAirScarcity",
      "description": "0 (ou 1 seule) carte anti-aérienne dans le deck.",
      "watch": { "cardSets": ["antiAirCards"] },
      "thresholds": [
        {
          "op": "eq",
          "value": 0,
          "shift": -4,
          "label": "{self} 0 carte anti-air"
        },
        {
          "op": "eq",
          "value": 1,
          "shift": -2,
          "label": "{self} 1 carte anti-air"
        }
      ]
    },
    {
      "id": "noBuilding",
      "description": "0 bâtiment dans le deck.",
      "watch": { "cardSets": ["allBuildings"] },
      "thresholds": [
        { "op": "eq", "value": 0, "shift": -3, "label": "{self} 0 bâtiment" }
      ]
    },
    {
      "id": "noSpell",
      "description": "0 sort dans le deck.",
      "watch": { "cardSets": ["smallSpells", "bigSpells"] },
      "thresholds": [
        { "op": "eq", "value": 0, "shift": -3, "label": "{self} 0 sort" }
      ]
    },
    {
      "id": "lowElixirScarcity",
      "description": "0 (ou 1 seule) carte à moins de 3 élixir dans le deck.",
      "watch": { "cardSets": ["lowElixirCards"] },
      "thresholds": [
        {
          "op": "eq",
          "value": 0,
          "shift": -4,
          "label": "{self} 0 carte <3 élixir"
        },
        {
          "op": "eq",
          "value": 1,
          "shift": -2,
          "label": "{self} 1 carte <3 élixir"
        }
      ]
    },
    {
      "id": "noWinCondition",
      "description": "0 win condition (même pseudo) reconnue dans le deck.",
      "metric": "winConditionCount",
      "thresholds": [
        {
          "op": "eq",
          "value": 0,
          "shift": -6,
          "label": "{self} 0 win condition"
        }
      ]
    }
  ],

  "layerClamp": 10
}
