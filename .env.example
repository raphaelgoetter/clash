# ─────────────────────────────────────────────────────────────
# .env.example — copiez ce fichier en .env et renseignez vos valeurs.
# Ne commitez JAMAIS le fichier .env.
# ─────────────────────────────────────────────────────────────

# Clé API Clash Royale officielle
# Obtenez la vôtre sur https://developer.clashroyale.com/
CLASH_API_KEY=your_clash_api_key_here

# Port du serveur Express (optionnel — défaut : 3000)
PORT=3000

# ---------- Paramètres du bot Discord ----------
# Clé publique pour vérifier les interactions entrantes (portail développeur Discord,
# rubrique "General Information").
DISCORD_PUBLIC_KEY=your_discord_public_key_hex

# Identifiant de l'application bot (aussi dans General Information).
# Requis pour enregistrer les commandes et construire les URLs webhook.
DISCORD_APP_ID=your_discord_app_id

# Token du bot (utilisé par le script d'enregistrement). Gardez-le secret !
DISCORD_TOKEN=your_discord_bot_token

# Liste blanche des serveurs Discord autorisés à utiliser le bot (Guild IDs).
# Séparez les identifiants par des virgules. Laissez vide pour autoriser tous les serveurs.
# Exemple : AUTHORIZED_GUILD_IDS=123456789012345678,987654321098765432
AUTHORIZED_GUILD_IDS=

# Vérifie qu'il s'agit d'un serveur où le bot est membre.
DISCORD_GUILD_ID=

# ID des channels de la famille.
DISCORD_CHANNEL_MEMBERS_Y8JUPC9C=
DISCORD_CHANNEL_MEMBERS_LRQP20V9=
DISCORD_CHANNEL_MEMBERS_QU9UQJRL=

# ID de thread optionnel : si défini pour un clan, les notifications automatiques
# (résumé GDC, arrivées/départs, joueurs inactifs, pronostics) sont postées dans
# ce thread au lieu du salon "Suivi clan N". Laisser vide = comportement inchangé.
DISCORD_THREAD_MEMBERS_Y8JUPC9C=
DISCORD_THREAD_MEMBERS_LRQP20V9=
DISCORD_THREAD_MEMBERS_QU9UQJRL=

# ID des membres autorisés à utiliser /late-ping.
# Séparez les identifiants par des virgules.
# Exemple : AUTHORIZED_PING_IDS=333264132277010432,1320036446211407994
AUTHORIZED_PING_IDS=

# ---------- Vercel Blob (stockage persistant des pronostics GDC) ----------
# Token généré depuis le dashboard Vercel → Storage → Blob.
# Optionnel en local : si absent, les données sont écrites dans data/.
# N'est plus utilisé par le jeu Frame (voir Upstash Redis ci-dessous) —
# Blob facture chaque put()/list() comme "Advanced Operation" avec un quota
# gratuit trop bas (2 000/mois) pour l'usage fréquent du jeu.
BLOB_READ_WRITE_TOKEN=

# ---------- Jeu Frame (devine le film) ----------
# Salon de test personnel (posté manuellement via `node scripts/postFrame.js`).
DISCORD_CHANNEL_FRAME_TEST=
# Salon public "Général" (posté via `node scripts/postFrame.js --public`,
# utilisé une fois le jeu validé, cf. .github/workflows/frames.yml).
DISCORD_CHANNEL_FRAME_PUBLIC=

# ---------- Upstash Redis (stockage du jeu Frame) ----------
# Générées automatiquement par l'intégration Vercel Marketplace
# "Upstash for Redis" (vercel integration add upstash/upstash-kv), à copier
# depuis .env.local après l'installation. Tier gratuit : 500 000
# commandes/mois, largement suffisant pour ce jeu.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
REDIS_URL=