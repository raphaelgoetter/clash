# ─────────────────────────────────────────────────────────────
# .env.example — copy this file to .env and fill in your values
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Clash Royale official API key
# Get yours at https://developer.clashroyale.com/
CLASH_API_KEY=your_clash_royale_api_key_here

# Port for the Express backend (optional — defaults to 3000)
PORT=3000
